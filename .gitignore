# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Env / secrets — never commit keys
.env
.env.*
*.local

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
npm-debug.log*

# Installed Vibe Kanban desktop app (landed inside the repo folder; not source)
Vibe Kanban/

# Downloaded media (feed-gemini.ps1 output) — context fuel, not source
media/

# Reviewer diff artifacts (written into a worktree for the read-only Reviewer to read). The wildcard
# also covers the delta diffs (.agent-review-delta.diff etc.) -- all are local, never committable.
.agent-review.diff
.agent-review*.diff

# Merge Gate plans (scripts/merge-gate.ps1) -- human-authored local merge authorizations, never committable
.merge-gate/

# Vendored minified ML bundles — too large for git and trigger false-positive secret scans
app/renderer/vendor/transformers.web.min.js
